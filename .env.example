# JWT Secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Supabase Postgres — Prisma runtime (PgBouncer port 6543)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Postgres — Prisma migrations (direct port 5432)
DIRECT_URL="postgresql://postgres.[ref]:[password]@db.qzzjpyepggwautckqeex.supabase.co:5432/postgres"

# Supabase Storage — product images (server-side only, never expose to browser)
SUPABASE_URL="https://qzzjpyepggwautckqeex.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Facturama — CFDI 4.0 via PAC Facturama
# Sandbox:    https://apisandbox.facturama.mx/
# Producción: https://api.facturama.mx/
FACTURAMA_BASE_URL="https://apisandbox.facturama.mx/"
# Credenciales Facturama (Basic Auth). Dejar vacío mientras se obtienen las reales.
FACTURAMA_USER="facturama_user"
FACTURAMA_PASSWORD="facturama_password"
# FACTURAMA_MOCK=true  →  usa FakeFacturamaGateway (sin red, UUIDs simulados). Default: true.
FACTURAMA_MOCK="true"

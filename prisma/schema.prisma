generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  branchId     String?  @map("branch_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  roles              UserRole[]
  branch             Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  sales              Sale[]            @relation("UserSales")
  quotesCreated      Quote[]           @relation("UserQuotesCreated")
  quotesAuthorized   Quote[]           @relation("UserQuotesAuthorized")
  returnsCreated     Return[]          @relation("UserReturnsCreated")
  returnsCancelled   Return[]          @relation("UserReturnsCancelled")
  payments           CustomerPayment[]

  @@index([branchId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique @db.VarChar(32)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@index([name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique @db.VarChar(64)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]

  @@index([key])
  @@map("permissions")
}

model RolePermission {
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  grantedAt    DateTime @default(now()) @map("granted_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model PaymentMethod {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(32)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  isCredit    Boolean  @default(false) @map("is_credit")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sales    Sale[]
  payments CustomerPayment[]

  @@index([code])
  @@map("payment_methods")
}

model Folio {
  id            String   @id @default(uuid())
  code          String   @unique @db.VarChar(32)
  name          String   @db.VarChar(100)
  prefix        String?  @db.VarChar(8)
  scope         String   @default("OPERATIONS") @db.VarChar(32)
  currentNumber Int      @default(0) @map("current_number")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sales    Sale[]
  quotes   Quote[]
  payments CustomerPayment[]

  @@index([code])
  @@index([scope])
  @@map("folios")
}

model Department {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(32)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  providerId  String?  @map("provider_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  provider Provider? @relation(fields: [providerId], references: [id], onDelete: Restrict)
  products Product[]

  @@index([code])
  @@index([providerId])
  @@map("departments")
}

model Branch {
  id             String   @id @default(uuid())
  code           String   @unique @db.VarChar(32)
  name           String   @db.VarChar(100)
  address        String?  @db.VarChar(300)
  phone          String?  @db.VarChar(30)
  email          String?  @db.VarChar(120)
  isHeadquarters Boolean  @default(false) @map("is_headquarters")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  inventory BranchInventory[]
  users     User[]
  sales     Sale[]
  quotes    Quote[]
  returns   Return[]
  payments  CustomerPayment[]
  invoices  Invoice[]

  @@index([code])
  @@map("branches")
}

model Provider {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(32)
  name        String   @db.VarChar(120)
  rfc         String   @unique @db.VarChar(13)
  legalName   String?  @map("legal_name") @db.VarChar(200)
  taxRegime   String?  @map("tax_regime") @db.VarChar(3)
  cfdiUse     String?  @map("cfdi_use") @db.VarChar(3)
  taxZipCode  String?  @map("tax_zip_code") @db.VarChar(5)
  email       String?  @db.VarChar(120)
  phone       String?  @db.VarChar(30)
  address     String?  @db.VarChar(300)
  contactName String?  @map("contact_name") @db.VarChar(120)
  notes       String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  departments Department[]

  @@index([code])
  @@index([rfc])
  @@index([name])
  @@map("providers")
}

model TaxRate {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(32)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  rate        Decimal  @db.Decimal(5, 4)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([code])
  @@map("tax_rates")
}

model Product {
  id             String   @id @default(uuid())
  code           String   @unique @db.VarChar(32)
  name           String   @db.VarChar(200)
  unit           String   @db.VarChar(32)
  satProductCode String?  @map("sat_product_code") @db.VarChar(16)
  departmentId   String   @map("department_id")
  taxRateId      String?  @map("tax_rate_id")
  ivaRate        Decimal? @map("iva_rate") @db.Decimal(5, 4)
  iepsRate       Decimal? @map("ieps_rate") @db.Decimal(5, 4)
  imageUrl       String?  @map("image_url") @db.Text
  isTaxable      Boolean  @default(false) @map("is_taxable")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  department    Department            @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  taxRate       TaxRate?              @relation(fields: [taxRateId], references: [id], onDelete: SetNull)
  prices        ProductPrice[]
  dosifications ProductDosification[]
  inventory     BranchInventory[]
  saleItems     SaleItem[]
  quoteItems    QuoteItem[]
  returnItems   ReturnItem[]

  @@index([code])
  @@index([name])
  @@index([departmentId])
  @@index([taxRateId])
  @@map("products")
}

model ProductPrice {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  name        String   @db.VarChar(60)
  price       Decimal  @db.Decimal(12, 4)
  minQuantity Int      @default(1) @map("min_quantity")
  discountPct Decimal? @map("discount_pct") @db.Decimal(5, 2)
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  saleItems   SaleItem[]
  quoteItems  QuoteItem[]
  returnItems ReturnItem[]

  @@unique([productId, name])
  @@index([productId])
  @@map("product_prices")
}

model ProductDosification {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  name      String   @db.VarChar(60)
  numParts  Int      @map("num_parts")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, name])
  @@index([productId])
  @@map("product_dosifications")
}

model BranchInventory {
  id               String   @id @default(uuid())
  branchId         String   @map("branch_id")
  productId        String   @map("product_id")
  quantity         Decimal  @default(0) @db.Decimal(14, 4)
  reservedQuantity Decimal  @default(0) @map("reserved_quantity") @db.Decimal(14, 4)
  reorderPoint     Decimal  @default(0) @map("reorder_point") @db.Decimal(14, 4)
  updatedAt        DateTime @updatedAt @map("updated_at")

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([branchId, productId])
  @@index([branchId])
  @@index([productId])
  @@map("branch_inventory")
}

model Customer {
  id             String   @id @default(uuid())
  code           String   @unique @db.VarChar(32)
  name           String   @db.VarChar(120)
  rfc            String   @unique @db.VarChar(13)
  legalName      String?  @map("legal_name") @db.VarChar(200)
  taxRegime      String?  @map("tax_regime") @db.VarChar(3)
  cfdiUse        String?  @map("cfdi_use") @db.VarChar(3)
  taxZipCode     String?  @map("tax_zip_code") @db.VarChar(5)
  email          String?  @db.VarChar(120)
  phone          String?  @db.VarChar(30)
  address        String?  @db.VarChar(300)
  contactName    String?  @map("contact_name") @db.VarChar(120)
  notes          String?  @db.Text
  creditLimit    Decimal? @map("credit_limit") @db.Decimal(12, 4)
  currentBalance Decimal  @default(0) @map("current_balance") @db.Decimal(12, 4)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  sales    Sale[]
  quotes   Quote[]
  returns  Return[]
  payments CustomerPayment[]
  invoices Invoice[]

  @@index([code])
  @@index([rfc])
  @@index([name])
  @@map("customers")
}

model Sale {
  id                 String    @id @default(uuid())
  folioId            String    @map("folio_id")
  folioNumber        Int       @map("folio_number")
  folioCode          String    @map("folio_code") @db.VarChar(40)
  branchId           String    @map("branch_id")
  customerId         String?   @map("customer_id")
  cashierId          String    @map("cashier_id") @db.Uuid
  paymentMethodId    String    @map("payment_method_id")
  quoteId            String?   @map("quote_id")
  status             String    @db.VarChar(20)
  paidAmount         Decimal   @default(0) @map("paid_amount") @db.Decimal(14, 4)
  paymentStatus      String    @default("paid") @map("payment_status") @db.VarChar(10)
  subtotal           Decimal   @db.Decimal(14, 4)
  taxTotal           Decimal   @map("tax_total") @db.Decimal(14, 4)
  total              Decimal   @db.Decimal(14, 4)
  notes              String?   @db.Text
  completedAt        DateTime? @map("completed_at")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason") @db.Text
  editedAt           DateTime? @map("edited_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  folio               Folio           @relation(fields: [folioId], references: [id], onDelete: Restrict)
  branch              Branch          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer            Customer?       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashier             User            @relation("UserSales", fields: [cashierId], references: [id], onDelete: Restrict)
  paymentMethod       PaymentMethod   @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  quote               Quote?          @relation("SaleFromQuote", fields: [quoteId], references: [id], onDelete: SetNull)
  items               SaleItem[]
  convertedFromQuotes Quote[]         @relation("QuoteConvertedSale")
  returns             Return[]
  payments            CustomerPayment[]
  invoices            Invoice[]

  @@unique([folioId, folioNumber])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@index([completedAt])
  @@index([quoteId])
  @@map("sales")
}

model CustomerPayment {
  id                 String    @id @default(uuid())
  saleId             String    @map("sale_id")
  customerId         String    @map("customer_id")
  userId             String    @map("user_id") @db.Uuid
  branchId           String    @map("branch_id")
  paymentMethodId    String    @map("payment_method_id")
  folioId            String    @map("folio_id")
  folioNumber        Int       @map("folio_number")
  folioCode          String    @map("folio_code")
  amount             Decimal   @db.Decimal(14, 4)
  status             String    @default("completed") @db.VarChar(20)
  notes              String?   @db.Text
  createdAt          DateTime  @default(now()) @map("created_at")
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason") @db.Text

  sale          Sale          @relation(fields: [saleId], references: [id], onDelete: Restrict)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  folio         Folio         @relation(fields: [folioId], references: [id], onDelete: Restrict)

  @@unique([folioId, folioNumber])
  @@index([saleId, status])
  @@index([customerId, status])
  @@index([userId, createdAt])
  @@index([branchId, createdAt])
  @@map("customer_payments")
}

model SaleItem {
  id                  String   @id @default(uuid())
  saleId              String   @map("sale_id")
  productId           String   @map("product_id")
  productPriceId      String?  @map("product_price_id")
  productCodeSnapshot String   @map("product_code_snapshot") @db.VarChar(32)
  productNameSnapshot String   @map("product_name_snapshot") @db.VarChar(200)
  priceNameSnapshot   String   @map("price_name_snapshot") @db.VarChar(60)
  quantity            Decimal  @db.Decimal(14, 4)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(12, 4)
  discountPct         Decimal? @map("discount_pct") @db.Decimal(5, 2)
  ivaRate             Decimal? @map("iva_rate") @db.Decimal(5, 4)
  iepsRate            Decimal? @map("ieps_rate") @db.Decimal(5, 4)
  lineSubtotal        Decimal  @map("line_subtotal") @db.Decimal(14, 4)
  lineTax             Decimal  @map("line_tax") @db.Decimal(14, 4)
  lineTotal           Decimal  @map("line_total") @db.Decimal(14, 4)

  sale         Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  productPrice ProductPrice? @relation(fields: [productPriceId], references: [id], onDelete: SetNull)
  returnItems  ReturnItem[]

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Quote {
  id                 String    @id @default(uuid())
  folioId            String    @map("folio_id")
  folioNumber        Int       @map("folio_number")
  folioCode          String    @map("folio_code") @db.VarChar(40)
  branchId           String    @map("branch_id")
  customerId         String?   @map("customer_id")
  creatorId          String    @map("creator_id") @db.Uuid
  status             String    @default("draft") @db.VarChar(20)
  subtotal           Decimal   @db.Decimal(14, 4)
  taxTotal           Decimal   @map("tax_total") @db.Decimal(14, 4)
  total              Decimal   @db.Decimal(14, 4)
  notes              String?   @db.Text
  expiresAt          DateTime? @map("expires_at")
  authorizedAt       DateTime? @map("authorized_at")
  authorizedBy       String?   @map("authorized_by") @db.Uuid
  cancelledAt        DateTime? @map("cancelled_at")
  cancellationReason String?   @map("cancellation_reason") @db.Text
  convertedAt        DateTime? @map("converted_at")
  convertedSaleId    String?   @map("converted_sale_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  folio          Folio       @relation(fields: [folioId], references: [id], onDelete: Restrict)
  branch         Branch      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer       Customer?   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  creator        User        @relation("UserQuotesCreated", fields: [creatorId], references: [id], onDelete: Restrict)
  authorizer     User?       @relation("UserQuotesAuthorized", fields: [authorizedBy], references: [id], onDelete: SetNull)
  convertedSale  Sale?       @relation("QuoteConvertedSale", fields: [convertedSaleId], references: [id], onDelete: SetNull)
  salesFromQuote Sale[]      @relation("SaleFromQuote")
  items          QuoteItem[]

  @@unique([folioId, folioNumber])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([convertedSaleId])
  @@map("quotes")
}

model QuoteItem {
  id                  String   @id @default(uuid())
  quoteId             String   @map("quote_id")
  productId           String   @map("product_id")
  productPriceId      String?  @map("product_price_id")
  productCodeSnapshot String   @map("product_code_snapshot") @db.VarChar(32)
  productNameSnapshot String   @map("product_name_snapshot") @db.VarChar(200)
  priceNameSnapshot   String   @map("price_name_snapshot") @db.VarChar(60)
  quantity            Decimal  @db.Decimal(14, 4)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(12, 4)
  discountPct         Decimal? @map("discount_pct") @db.Decimal(5, 2)
  ivaRate             Decimal? @map("iva_rate") @db.Decimal(5, 4)
  iepsRate            Decimal? @map("ieps_rate") @db.Decimal(5, 4)
  lineSubtotal        Decimal  @map("line_subtotal") @db.Decimal(14, 4)
  lineTax             Decimal  @map("line_tax") @db.Decimal(14, 4)
  lineTotal           Decimal  @map("line_total") @db.Decimal(14, 4)

  quote        Quote         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  productPrice ProductPrice? @relation(fields: [productPriceId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([productId])
  @@map("quote_items")
}

model Return {
  id                 String    @id @default(uuid())
  saleId             String    @map("sale_id")
  branchId           String    @map("branch_id")
  customerId         String?   @map("customer_id")
  creatorId          String    @map("creator_id") @db.Uuid
  status             String    @default("completed") @db.VarChar(20)
  reason             String    @db.Text
  returnedAt         DateTime  @map("returned_at")
  refundSubtotal     Decimal   @map("refund_subtotal") @db.Decimal(14, 4)
  refundTax          Decimal   @map("refund_tax") @db.Decimal(14, 4)
  refundTotal        Decimal   @map("refund_total") @db.Decimal(14, 4)
  notes              String?   @db.Text
  cancelledAt        DateTime? @map("cancelled_at")
  cancelledBy        String?   @map("cancelled_by") @db.Uuid
  cancellationReason String?   @map("cancellation_reason") @db.Text
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  sale           Sale      @relation(fields: [saleId], references: [id], onDelete: Restrict)
  branch         Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  creator        User      @relation("UserReturnsCreated", fields: [creatorId], references: [id], onDelete: Restrict)
  cancelledByUser User?    @relation("UserReturnsCancelled", fields: [cancelledBy], references: [id], onDelete: SetNull)
  items          ReturnItem[]

  @@index([saleId])
  @@index([branchId])
  @@index([customerId])
  @@index([status])
  @@index([returnedAt])
  @@index([createdAt])
  @@map("returns")
}

model ReturnItem {
  id                  String   @id @default(uuid())
  returnId            String   @map("return_id")
  saleItemId          String   @map("sale_item_id")
  productId           String   @map("product_id")
  productPriceId      String?  @map("product_price_id")
  productCodeSnapshot String   @map("product_code_snapshot") @db.VarChar(32)
  productNameSnapshot String   @map("product_name_snapshot") @db.VarChar(200)
  priceNameSnapshot   String   @map("price_name_snapshot") @db.VarChar(60)
  quantity            Decimal  @db.Decimal(14, 4)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(12, 4)
  discountPct         Decimal? @map("discount_pct") @db.Decimal(5, 2)
  ivaRate             Decimal? @map("iva_rate") @db.Decimal(5, 4)
  iepsRate            Decimal? @map("ieps_rate") @db.Decimal(5, 4)
  lineSubtotal        Decimal  @map("line_subtotal") @db.Decimal(14, 4)
  lineTax             Decimal  @map("line_tax") @db.Decimal(14, 4)
  lineTotal           Decimal  @map("line_total") @db.Decimal(14, 4)

  return       Return       @relation(fields: [returnId], references: [id], onDelete: Cascade)
  saleItem     SaleItem     @relation(fields: [saleItemId], references: [id], onDelete: Restrict)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  productPrice ProductPrice? @relation(fields: [productPriceId], references: [id], onDelete: SetNull)

  @@index([returnId])
  @@index([saleItemId])
  @@index([productId])
  @@map("return_items")
}

model Invoice {
  id                    String    @id @default(uuid())
  uuid                  String?   @db.VarChar(40)
  facturamaCfdiId       String?   @map("facturama_cfdi_id") @db.VarChar(40)
  status                String    @db.VarChar(20)
  cfdiType              String    @default("I") @map("cfdi_type") @db.VarChar(2)
  cfdiUse               String    @map("cfdi_use") @db.VarChar(8)
  paymentForm           String    @default("01") @map("payment_form") @db.VarChar(4)
  paymentMethod         String    @default("PUE") @map("payment_method") @db.VarChar(4)
  receiverRfc           String    @map("receiver_rfc") @db.VarChar(14)
  receiverName          String    @map("receiver_name") @db.VarChar(200)
  receiverCfdiUse       String    @map("receiver_cfdi_use") @db.VarChar(8)
  receiverFiscalRegime  String    @map("receiver_fiscal_regime") @db.VarChar(4)
  receiverTaxZipCode    String    @map("receiver_tax_zip_code") @db.VarChar(5)
  currency              String    @default("MXN") @db.VarChar(3)
  subtotal              Decimal   @db.Decimal(14, 4)
  taxTotal              Decimal   @map("tax_total") @db.Decimal(14, 4)
  total                 Decimal   @db.Decimal(14, 4)
  xmlUrl                String?   @map("xml_url") @db.Text
  pdfUrl                String?   @map("pdf_url") @db.Text
  saleId                String?   @map("sale_id")
  branchId              String    @map("branch_id")
  customerId            String?   @map("customer_id")
  creatorId             String    @map("creator_id") @db.Uuid
  cancellationMotive    String?   @map("cancellation_motive") @db.VarChar(2)
  uuidReplacement       String?   @map("uuid_replacement") @db.VarChar(40)
  cancelledAt           DateTime? @map("cancelled_at")
  cancelledBy           String?   @map("cancelled_by") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  sale     Sale?     @relation(fields: [saleId], references: [id], onDelete: SetNull)
  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    InvoiceItem[]

  @@index([saleId])
  @@index([branchId])
  @@index([status])
  @@index([uuid])
  @@index([receiverRfc])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id                  String   @id @default(uuid())
  invoiceId           String   @map("invoice_id")
  productId           String?  @map("product_id")
  productCodeSnapshot String   @map("product_code_snapshot") @db.VarChar(32)
  productNameSnapshot String   @map("product_name_snapshot") @db.VarChar(200)
  satProductCode      String?  @map("sat_product_code") @db.VarChar(8)
  satUnitCode         String?  @map("sat_unit_code") @db.VarChar(10)
  unit                String   @db.VarChar(60)
  quantity            Decimal  @db.Decimal(14, 4)
  unitPrice           Decimal  @map("unit_price") @db.Decimal(14, 4)
  discountPct         Decimal? @map("discount_pct") @db.Decimal(5, 2)
  ivaRate             Decimal  @map("iva_rate") @db.Decimal(6, 4)
  iepsRate            Decimal  @map("ieps_rate") @db.Decimal(6, 4)
  taxObject           String   @map("tax_object") @db.VarChar(2)
  lineSubtotal        Decimal  @map("line_subtotal") @db.Decimal(14, 4)
  lineIva             Decimal  @map("line_iva") @db.Decimal(14, 4)
  lineIeps            Decimal  @map("line_ieps") @db.Decimal(14, 4)
  lineTotal           Decimal  @map("line_total") @db.Decimal(14, 4)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}
